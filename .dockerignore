tests/

# Alembic migrations (not needed at runtime in Docker – DB auto-migrates)
alembic/

# Wrapper entry point (not needed, real entry is src/main.py)
main.py
# Cloud Run entry point (only used by Dockerfile.cloudrun, not the main Dockerfile)
scripts/run_cloudrun.py
