# =============================================================================
# DC Trade Toolbox - Environment Configuration
# Copy this file to .env and adjust values.
# =============================================================================

# -- Required ---------------------------------------------------------------
# Your DemocracyCraft API key (required!)
DC_API_KEY=your_api_key_here

# -- Optional: Branding ----------------------------------------------------
COMPANY_NAME=Fishy Business

# -- Optional: Database ----------------------------------------------------
# Leave empty (or comment out) for SQLite (data/dc_trade.db) - no setup needed.
#
# For PostgreSQL (Docker with --profile db):
#   docker compose --profile db up -d
# Then set both variables below:
DATABASE_URL=postgres://dctrade:YOUR_PASSWORD_HERE@postgres:5432/dctrade
POSTGRES_PASSWORD=YOUR_PASSWORD_HERE
#
# For remote PostgreSQL (production), change the host in DATABASE_URL.
# When DATABASE_URL is non-empty, the app uses PostgreSQL; otherwise SQLite.
#
# -- Connecting from external tools (DBeaver, TablePlus, pgAdmin, etc.) ----
# While Docker is running, you can connect to the PostgreSQL database
# using any SQL client with these credentials:
#   Host:     localhost
#   Port:     5432
#   Database: dctrade
#   User:     dctrade
#   Password: (the value of POSTGRES_PASSWORD)
#   SSL:      disabled
#
# Example connection string for external tools:
#   postgres://dctrade:YOUR_PASSWORD_HERE@localhost:5432/dctrade
#
# Note: The "localhost" host works because docker-compose maps port 5432
# to your host machine. The app internally uses "postgres" (Docker DNS).

# -- Optional: API Settings ------------------------------------------------
API_TIMEOUT=10
API_RETRIES=3
API_RETRY_DELAY=2

# -- Optional: Trading -----------------------------------------------------
MIN_ACCEPTABLE_PERCENT=0.85
CACHE_DURATION=21600

# -- Optional: Server Ports ------------------------------------------------
STREAMLIT_PORT=8501
API_PORT=8000

# -- Optional: Multi-Company / Discord Auth --------------------------------
# Discord OAuth 2.0 - set these for production
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# For local dev: http://localhost:8501/  For production: https://yourdomain.com/
DISCORD_REDIRECT_URI=http://localhost:8501/
# Comma-separated list of Discord user IDs that have admin access
ADMIN_DISCORD_IDS=
# Trial duration in days (default: 3)
TRIAL_DAYS=3
# Session secret for cookie signing (auto-generated if empty)
SESSION_SECRET=

# -- Optional: Debug -------------------------------------------------------
DEBUG=false