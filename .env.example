# =============================================================================
# DC Trade Toolbox – Environment Configuration
# Copy this file to .env and adjust values.
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────
# Your DemocracyCraft API key (required!)
DC_API_KEY=your_api_key_here

# ── Optional: Branding ───────────────────────────────────────────────────
COMPANY_NAME=Fishy Business

# ── Optional: Database ───────────────────────────────────────────────────
# Leave empty for SQLite (data/dc_trade.db).
# For production with PostgreSQL, set:
# DATABASE_URL=postgres://user:password@host:5432/dctrade
DATABASE_URL=

# ── Optional: API Settings ───────────────────────────────────────────────
API_TIMEOUT=10
API_RETRIES=3
API_RETRY_DELAY=2

# ── Optional: Trading ────────────────────────────────────────────────────
MIN_ACCEPTABLE_PERCENT=0.85
CACHE_DURATION=21600

# ── Optional: Server Ports ───────────────────────────────────────────────
STREAMLIT_PORT=8501
API_PORT=8000

# ── Optional: Multi-Company / Discord Auth ───────────────────────────────
# Discord OAuth 2.0 — set these for production
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# For local dev: http://localhost:8501/  For production: https://yourdomain.com/
DISCORD_REDIRECT_URI=http://localhost:8501/
# Comma-separated list of Discord user IDs that have admin access
ADMIN_DISCORD_IDS=
# Trial duration in days (default: 3)
TRIAL_DAYS=3
# Session secret for cookie signing (auto-generated if empty)
SESSION_SECRET=

# ── Optional: Debug ──────────────────────────────────────────────────────
DEBUG=false
