# =============================================================================
# DC Trade Toolbox – Environment Configuration
# Copy this file to .env and adjust values.
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────
# Your DemocracyCraft API key (required!)
DC_API_KEY=your_api_key_here

# ── Optional: Branding ───────────────────────────────────────────────────
COMPANY_NAME=Fishy Business

# ── Optional: Database ───────────────────────────────────────────────────
# Leave empty for SQLite (data/dc_trade.db).
# For production with PostgreSQL, set:
# DATABASE_URL=postgres://user:password@host:5432/dctrade
DATABASE_URL=

# ── Optional: API Settings ───────────────────────────────────────────────
API_TIMEOUT=10
API_RETRIES=3
API_RETRY_DELAY=2

# ── Optional: Trading ────────────────────────────────────────────────────
MIN_ACCEPTABLE_PERCENT=0.85
CACHE_DURATION=21600

# ── Optional: Server Ports ───────────────────────────────────────────────
STREAMLIT_PORT=8501
API_PORT=8000

# ── Optional: Debug ──────────────────────────────────────────────────────
DEBUG=false